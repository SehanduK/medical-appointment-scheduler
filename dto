package com.medical.appointment.dto;

import jakarta.validation.constraints.Future;
import jakarta.validation.constraints.NotBlank;
import jakarta.validation.constraints.NotNull;
import lombok.Getter;
import lombok.Setter;
import lombok.NoArgsConstructor;
import lombok.AllArgsConstructor;

import java.time.LocalDate;
import java.time.LocalTime;

/**
 * ============================================================
 *  OOP CONCEPT: ENCAPSULATION + INFORMATION HIDING
 * ============================================================
 *
 *  INFORMATION HIDING:
 *    - DTOs (Data Transfer Objects) hide the internal entity structure.
 *    - Clients send/receive DTOs — they never see the JPA entity directly.
 *    - This protects the domain model from external changes.
 *
 *  ENCAPSULATION:
 *    - All fields are private with Lombok getters/setters.
 *    - Validation annotations enforce data rules at the boundary.
 * ============================================================
 */
@Getter
@Setter
@NoArgsConstructor
@AllArgsConstructor
public class AppointmentRequestDTO {

    @NotNull(message = "Patient ID is required")
    private Long patientId;

    @NotNull(message = "Doctor ID is required")
    private Long doctorId;

    @NotNull(message = "Appointment date is required")
    @Future(message = "Appointment date must be in the future")
    private LocalDate appointmentDate;

    @NotNull(message = "Appointment time is required")
    private LocalTime appointmentTime;

    @NotBlank(message = "Appointment type is required")
    private String appointmentType;

    private String notes;
}
